<!-- views/login.ejs -->
<!DOCTYPE html>
<html lang="fr">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="stylesheet" href="./assets/css/styles.css"/>
   <title>Login</title>
</head>
<body>
      <div class="bloc">
         <img src="./assets/images/logo.png" class="logo"/>

         <div class="paragraph">
            Vérifiez votre boite mail et rentrez le code de confirmation
         </div>
         
         <form class="form" action="/check_login_code" method="POST">
            <div class="form-group verify">
               <label for="code">code</label>
               <input name="code" class="input" type="text" placeholder="ex : 12345">
            </div>

            <input name="email" type="hidden" value="<%=email%>">

            <div class="warning">
               <%= error_message %>
            </div>

            <div class="button_area">
               <button class="button" type="submit">Continuer</button>
            </div>
         </form>
      </div>
</body>
</html>

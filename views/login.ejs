<!-- views/login.ejs -->
<!DOCTYPE html>
<html lang="fr">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="stylesheet" href="/assets/css/styles.css"/>
   <title>Login</title>
</head>
<body>
   <div class="bloc">
      <img src="./assets/images/logo.png" class="logo"/>

      <div class="warning">
         <%= error_message %>
      </div>
      
      <form action="/check_login" method="POST">
         <div class="form-group email">
            <label for="email">Email</label>
            <input name="email" class="input" type="text" placeholder="ex : securit@gmail.com">
         </div>

         <div class="form-group password">
            <label for="password">Password</label>
            <input name="password" class="input" type="password" placeholder="********"><br>
         </div> 

         <div class="button_area">
            <button class="button" type="submit">Se Connecter</button>
         </div>
      </form>

      <div class="option">
         <div class="register" action="/register" method="GET">
            <a href="/register">Créer un compte</a>
         </div>

         <div class="forgotten">
            <a href="/forgotten_password">Mot de passe oublié ?</a>
         </div>
      </div>
   </div>
</body>
</html>

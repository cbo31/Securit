generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum role {
  INSPECTOR 
  ADMIN

}

model user {
  id          Int       @default(autoincrement()) @id
  name        String
  email       String    @unique
  password    String    
  role        role    @default(INSPECTOR)

  visits      visit[]
}

model company {
  id          Int        @default(autoincrement()) @id
  name        String
  address     String    

  visits      visit[]
}

model visit {
  id               Int         @default(autoincrement()) @id
  date             DateTime
  company_id       Int         @unique
  inspector_id     Int 
  report           String?

  company          company    @relation(fields: [company_id], references: [id])
  inspector        user       @relation(fields: [inspector_id], references: [id])
}

